page {
  background: #121212;
  color: #ffffff;
  font-size: 28rpx;
  box-sizing: border-box;
}

.container {
  padding: 24rpx;
  min-height: 100vh;
}

.panel {
  background: #181818;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.eyebrow {
  display: block;
  font-size: 22rpx;
  color: #1ed760;
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.subtitle {
  color: #b3b3b3;
  font-size: 24rpx;
  margin-bottom: 24rpx;
}

.metric-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.metric-card {
  background: #252525;
  border-radius: 20rpx;
  padding: 24rpx;
}

.metric-label {
  color: #b3b3b3;
  font-size: 22rpx;
}

.metric-value {
  font-size: 36rpx;
  font-weight: 700;
  margin-top: 8rpx;
}

.metric-value.accent {
  color: #1ed760;
}

.btn-primary {
  background: #1ed760;
  color: #000000;
  border-radius: 999rpx;
  font-weight: 700;
}

.btn-secondary {
  background: #252525;
  color: #ffffff;
  border-radius: 999rpx;
}

.empty-block {
  text-align: center;
  padding: 80rpx 24rpx;
  color: #b3b3b3;
}

.list-item {
  background: #252525;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.list-item-title {
  font-size: 30rpx;
  font-weight: 600;
}

.list-item-meta {
  color: #b3b3b3;
  font-size: 24rpx;
  margin-top: 8rpx;
}

.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  background: #333333;
  color: #1ed760;
  font-size: 22rpx;
  margin-right: 8rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  color: #b3b3b3;
  margin-bottom: 12rpx;
}

.form-input {
  background: #252525;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  color: #ffffff;
}

.menu-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.menu-item {
  background: #252525;
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  text-align: center;
}

.menu-item text {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
}

.risk-card {
  background: #252525;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
  border-left: 6rpx solid #1ed760;
}

.risk-card.WARNING {
  border-left-color: #f59e0b;
}

.risk-card.DANGER {
  border-left-color: #ef4444;
}
