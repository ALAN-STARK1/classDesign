<view class="container login-page">
  <view class="hero">
    <text class="eyebrow">INDRAS</text>
    <text class="title">智能健康膳食</text>
    <text class="subtitle">登录后开始你的营养管理之旅</text>
  </view>

  <view class="panel">
    <view class="form-item">
      <text class="form-label">用户名</text>
      <input class="form-input" value="{{username}}" placeholder="请输入用户名" bindinput="onUsernameInput" />
    </view>
    <view class="form-item">
      <text class="form-label">密码</text>
      <input class="form-input" password value="{{password}}" placeholder="请输入密码" bindinput="onPasswordInput" />
    </view>
    <button class="btn-primary" loading="{{loading}}" bindtap="onLogin">登录</button>
    <button class="btn-secondary link-btn" bindtap="goRegister">没有账号？去注册</button>
  </view>
</view>
