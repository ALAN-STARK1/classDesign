.textarea {
  width: 100%;
  min-height: 200rpx;
  background: #252525;
  border-radius: 16rpx;
  padding: 20rpx;
  color: #fff;
  margin-bottom: 16rpx;
  box-sizing: border-box;
}

.btn-row {
  display: flex;
  gap: 16rpx;
}

.btn-row button {
  flex: 1;
}

.btn-row button::after {
  border: none;
}
