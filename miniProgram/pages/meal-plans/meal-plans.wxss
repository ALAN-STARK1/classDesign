.btn-row {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.btn-row button {
  flex: 1;
}

.btn-row button::after {
  border: none;
}

.secondary-row {
  margin-top: 12rpx;
}

.item-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.item-main {
  flex: 1;
}

.action-btn {
  color: #1ed760;
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  flex-shrink: 0;
}

.modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: flex-end;
  z-index: 100;
}

.modal-panel {
  width: 100%;
  max-height: 70vh;
  background: #181818;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 24rpx;
  box-sizing: border-box;
}

.modal-scroll {
  max-height: 45vh;
  margin: 16rpx 0;
}

.candidate-item:active {
  opacity: 0.8;
}

.modal-panel .btn-secondary::after {
  border: none;
}
