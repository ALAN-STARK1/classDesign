<view class="container">
  <view class="panel">
    <text class="eyebrow">MEAL PLAN</text>
    <text class="title">每日膳食计划</text>

    <picker mode="date" value="{{date}}" bindchange="onDateChange">
      <view class="list-item">
        <text class="list-item-title">选择日期</text>
        <text class="list-item-meta">{{date}}</text>
      </view>
    </picker>

    <button class="btn-primary" loading="{{generating}}" bindtap="onGenerate">生成当日计划</button>
  </view>

  <view wx:if="{{loading}}" class="empty-block">加载中...</view>
  <view wx:elif="{{!items.length}}" class="empty-block">暂无计划，点击上方按钮生成</view>

  <view wx:else>
    <view wx:for="{{items}}" wx:key="id" class="list-item" bindtap="goRecipeDetail" data-id="{{item.recipeId}}">
      <view class="row">
        <text class="tag">{{item.mealTypeLabel}}</text>
        <text class="list-item-title">{{item.recipeName || item.name}}</text>
      </view>
      <text class="list-item-meta">{{item.calorie || 0}} kcal · {{item.protein || 0}}g 蛋白</text>
    </view>
  </view>
</view>
